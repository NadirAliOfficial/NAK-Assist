<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ NAK Assist"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by Nadir Ali Khan — Team NAK"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="24dp" />

        <!-- Stats -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 TODAY"
                    android:textSize="10sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/tvStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No data yet"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Permissions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETUP"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOverlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Grant Overlay Permission"
            android:backgroundTint="#1B5E20"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Enable Accessibility Service"
            android:backgroundTint="#2E7D32"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotification"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Enable Notification Access"
            android:backgroundTint="#388E3C"
            android:textColor="@android:color/white"
            android:layout_marginBottom="8dp"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAwayMode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💤 Away Mode: OFF"
            android:backgroundTint="#555555"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <!-- API Keys -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GROQ API KEYS"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get free keys at console.groq.com — enter one per line, no limit"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etApiKeys"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="gsk_..."
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="#555555"
            android:background="?attr/colorSurfaceVariant"
            android:padding="12dp"
            android:textSize="13sp"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:maxLines="20"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveKeys"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save API Keys"
            android:backgroundTint="#1565C0"
            android:textColor="@android:color/white"
            android:layout_marginBottom="24dp"
            app:cornerRadius="12dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Not ready"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Tap = Smart Reply  |  ⚡⚡ Double Tap = More Modes\n💡 Add Away Mode tile from Quick Settings"
            android:textSize="11sp"
            android:textColor="#555555"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>
