<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NAK Assist"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by Nadir Ali Khan — Team NAK"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginBottom="40dp" />

    <Button
        android:id="@+id/btnOverlay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Grant Overlay Permission"
        android:backgroundTint="#1B5E20"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Enable Accessibility Service"
        android:backgroundTint="#2E7D32"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnNotification"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Enable Notification Access"
        android:backgroundTint="#388E3C"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnAwayMode"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="💤 Away Mode: OFF"
        android:backgroundTint="#555555"
        android:textColor="@android:color/white"
        android:layout_marginBottom="28dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Not ready"
        android:textSize="13sp"
        android:textColor="#999999"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ Tap = Smart Reply  |  ⚡⚡ Double = Summarize  |  Hold = More Modes"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:gravity="center" />

</LinearLayout>
