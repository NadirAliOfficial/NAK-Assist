<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EE1B1B1B"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ NAK Assist"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCloseMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btnSmartReply" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="💬 Reply" android:backgroundTint="#1B5E20"
                    android:textColor="@android:color/white" android:textSize="12sp" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btnSummarize" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="📋 Summarize" android:backgroundTint="#1B5E20"
                    android:textColor="@android:color/white" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btnImprove" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="✨ Improve" android:backgroundTint="#2E7D32"
                    android:textColor="@android:color/white" android:textSize="12sp" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btnRewrite" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="🔄 Rewrite" android:backgroundTint="#2E7D32"
                    android:textColor="@android:color/white" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btnShorten" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="✂️ Shorten" android:backgroundTint="#388E3C"
                    android:textColor="@android:color/white" android:textSize="12sp" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btnProofread" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="✅ Proofread" android:backgroundTint="#388E3C"
                    android:textColor="@android:color/white" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Row 4 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btnProfessional" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="💼 Professional" android:backgroundTint="#1B5E20"
                    android:textColor="@android:color/white" android:textSize="12sp" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btnFriendly" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="😊 Friendly" android:backgroundTint="#1B5E20"
                    android:textColor="@android:color/white" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Row 5 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <Button android:id="@+id/btnTranslate" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="🌐 Translate EN" android:backgroundTint="#2E7D32"
                    android:textColor="@android:color/white" android:textSize="12sp" android:layout_marginEnd="6dp"/>
                <Button android:id="@+id/btnTemplates" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:text="📁 Templates" android:backgroundTint="#2E7D32"
                    android:textColor="@android:color/white" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Custom command -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText android:id="@+id/etCustomCommand" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="44dp" android:hint="Custom command..." android:textColor="#FFFFFF"
                    android:textColorHint="#888888" android:background="#333333" android:paddingHorizontal="10dp"
                    android:textSize="13sp" android:layout_marginEnd="8dp" android:inputType="text"/>
                <Button android:id="@+id/btnCustomSend" android:layout_width="wrap_content"
                    android:layout_height="44dp" android:text="Go" android:backgroundTint="#1B5E20"
                    android:textColor="@android:color/white"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
