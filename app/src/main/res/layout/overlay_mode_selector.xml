<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F2111111"
    android:paddingHorizontal="14dp"
    android:paddingTop="14dp"
    android:paddingBottom="10dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ NAK Assist"
            android:textColor="#4CAF50"
            android:textSize="15sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvCloseMode"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textColor="#666666"
            android:textSize="16sp"
            android:gravity="center" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AI Tools label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI TOOLS"
                android:textColor="#444444"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <!-- Row 1: Reply + Summarize -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btnSmartReply"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
                    android:text="💬 Reply" android:backgroundTint="#1A3A1A"
                    android:textColor="#4CAF50" android:textSize="12sp" android:layout_marginEnd="5dp"/>
                <Button android:id="@+id/btnSummarize"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
                    android:text="📋 Summarize" android:backgroundTint="#1A1A3A"
                    android:textColor="#7986CB" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Row 2: Improve + Shorten -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btnImprove"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
                    android:text="✨ Improve" android:backgroundTint="#2A1A1A"
                    android:textColor="#EF9A9A" android:textSize="12sp" android:layout_marginEnd="5dp"/>
                <Button android:id="@+id/btnShorten"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
                    android:text="✂️ Shorten" android:backgroundTint="#1A2A1A"
                    android:textColor="#A5D6A7" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Row 3: Proofread + Translate -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="14dp">
                <Button android:id="@+id/btnProofread"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
                    android:text="✅ Proofread" android:backgroundTint="#1A1A2A"
                    android:textColor="#CE93D8" android:textSize="12sp" android:layout_marginEnd="5dp"/>
                <Button android:id="@+id/btnTranslate"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
                    android:text="🌐 Translate" android:backgroundTint="#1A2A2A"
                    android:textColor="#80DEEA" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#222222" android:layout_marginBottom="12dp"/>

            <!-- Automation label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AUTOMATION"
                android:textColor="#444444"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <!-- Stay Online -->
            <Button android:id="@+id/btnAutoRefreshToggle"
                android:layout_width="match_parent" android:layout_height="42dp"
                android:text="🟢 Stay Online: OFF"
                android:backgroundTint="#1A2A1A"
                android:textColor="#81C784" android:textSize="13sp"
                android:layout_marginBottom="6dp"/>

            <!-- Interval picker -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <Button android:id="@+id/btnInterval5"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="34dp"
                    android:text="5s" android:backgroundTint="#1E1E1E"
                    android:textColor="#888888" android:textSize="12sp" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnInterval10"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="34dp"
                    android:text="10s" android:backgroundTint="#1E1E1E"
                    android:textColor="#888888" android:textSize="12sp" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnInterval30"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="34dp"
                    android:text="30s" android:backgroundTint="#1E1E1E"
                    android:textColor="#888888" android:textSize="12sp" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnInterval60"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="34dp"
                    android:text="60s" android:backgroundTint="#1E1E1E"
                    android:textColor="#888888" android:textSize="12sp"/>
            </LinearLayout>

            <!-- Away Mode -->
            <Button android:id="@+id/btnAwayModeToggle"
                android:layout_width="match_parent" android:layout_height="42dp"
                android:text="💤 Away Mode: OFF"
                android:backgroundTint="#1E1A2A"
                android:textColor="#CE93D8" android:textSize="13sp"
                android:layout_marginBottom="12dp"/>

            <!-- Custom command -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText android:id="@+id/etCustomCommand"
                    android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp"
                    android:hint="Custom instruction..." android:textColor="#FFFFFF"
                    android:textColorHint="#444444" android:background="#1E1E1E"
                    android:paddingHorizontal="10dp" android:textSize="12sp"
                    android:layout_marginEnd="6dp" android:inputType="text"/>
                <Button android:id="@+id/btnCustomSend"
                    android:layout_width="56dp" android:layout_height="42dp"
                    android:text="Go" android:backgroundTint="#1A3A1A"
                    android:textColor="#4CAF50"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
