<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F21C1C1E"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ NAK Assist"
            android:textColor="#30D158"
            android:textSize="15sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvCloseMode"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textColor="#636366"
            android:textSize="16sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Stay Online -->
    <Button android:id="@+id/btnAutoRefreshToggle"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:text="🟢 Stay Online: OFF"
        android:backgroundTint="#1A2A1A"
        android:textColor="#30D158" android:textSize="14sp"
        android:layout_marginBottom="8dp"/>

    <!-- Interval picker -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnInterval5"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp"
            android:text="5s" android:backgroundTint="#2C2C2E"
            android:textColor="#8E8E93" android:textSize="13sp" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnInterval10"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp"
            android:text="10s" android:backgroundTint="#2C2C2E"
            android:textColor="#8E8E93" android:textSize="13sp" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnInterval30"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp"
            android:text="30s" android:backgroundTint="#2C2C2E"
            android:textColor="#8E8E93" android:textSize="13sp" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnInterval60"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp"
            android:text="60s" android:backgroundTint="#2C2C2E"
            android:textColor="#8E8E93" android:textSize="13sp"/>
    </LinearLayout>

    <!-- Away Mode -->
    <Button android:id="@+id/btnAwayModeToggle"
        android:layout_width="match_parent" android:layout_height="50dp"
        android:text="💤 Away Mode: OFF"
        android:backgroundTint="#2C1F3A"
        android:textColor="#BF5AF2" android:textSize="14sp"/>

</LinearLayout>
